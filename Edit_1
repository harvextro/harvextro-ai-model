import os
os.chdir('/kaggle/working/darknet_new')

VIDEO_PATH = '/kaggle/input/datasets/dilniwijesinghe/output1/video1.mp4'  # <-- update filename
OUTPUT_VIDEO = '/kaggle/working/detected_output.mp4'
WEIGHTS = '/kaggle/working/backup/yolov3-tiny-custom_last.weights'
CONFIG  = '/kaggle/working/darknet_new/cfg/yolov3-tiny-custom.cfg'
NAMES   = '/kaggle/working/darknet_new/data/obj.names'
THRESH  = 0.3

print(f'Video exists: {os.path.exists(VIDEO_PATH)}')
print(f'Weights exists: {os.path.exists(WEIGHTS)}')
print(f'Config exists: {os.path.exists(CONFIG)}')

import cv2
import numpy as np
import time

# Load class names
with open(NAMES, "r") as f:
    class_names = [line.strip() for line in f.readlines()]

# Assign a unique color per class
np.random.seed(42)
colors = np.random.randint(0, 255, size=(len(class_names), 3), dtype=np.uint8).tolist()

# Load YOLO network
print("Loading YOLO model...")
net = cv2.dnn.readNetFromDarknet(CONFIG, WEIGHTS)
net.setPreferableBackend(cv2.dnn.DNN_BACKEND_CUDA)
net.setPreferableTarget(cv2.dnn.DNN_TARGET_CUDA)
layer_names = net.getLayerNames()
output_layers = [layer_names[i - 1] for i in net.getUnconnectedOutLayers().flatten()]
print(f"✅ Model loaded! Output layers: {output_layers}")

# Open video
cap = cv2.VideoCapture(VIDEO_PATH)
if not cap.isOpened():
    raise FileNotFoundError(f"Cannot open video: {VIDEO_PATH}")

frame_w      = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
frame_h      = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
fps          = cap.get(cv2.CAP_PROP_FPS) or 25
total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
print(f"Video: {frame_w}x{frame_h} @ {fps:.1f} FPS | Total frames: {total_frames}")

# Video writer
fourcc = cv2.VideoWriter_fourcc(*"mp4v")
out = cv2.VideoWriter(OUTPUT_VIDEO, fourcc, fps, (frame_w, frame_h))

net.setPreferableBackend(cv2.dnn.DNN_BACKEND_OPENCV)
net.setPreferableTarget(cv2.dnn.DNN_TARGET_CPU)

frame_idx = 0
start_time = time.time()

while True:
    ret, frame = cap.read()
    if not ret:
        break

    frame_idx += 1

    blob = cv2.dnn.blobFromImage(frame, 1/255.0, (416, 416), swapRB=True, crop=False)
    net.setInput(blob)
    outs = net.forward(output_layers)

    boxes, confidences, class_ids = [], [], []
    for out_layer in outs:
        for detection in out_layer:
            scores = detection[5:]
            class_id = int(np.argmax(scores))
            confidence = float(scores[class_id])
            if confidence > THRESH:
                cx = int(detection[0] * frame_w)
                cy = int(detection[1] * frame_h)
                w  = int(detection[2] * frame_w)
                h  = int(detection[3] * frame_h)
                boxes.append([cx - w // 2, cy - h // 2, w, h])
                confidences.append(confidence)
                class_ids.append(class_id)

    indices = cv2.dnn.NMSBoxes(boxes, confidences, THRESH, 0.4)
    if len(indices) > 0:
        for i in indices.flatten():
            x, y, w, h = boxes[i]
            label = f"{class_names[class_ids[i]]}: {confidences[i]:.2f}"
            color = colors[class_ids[i]]
            cv2.rectangle(frame, (x, y), (x + w, y + h), color, 2)
            cv2.putText(frame, label, (x, y - 8), cv2.FONT_HERSHEY_SIMPLEX, 0.6, color, 2)

    cv2.putText(frame, f"Frame {frame_idx}/{total_frames}",
                (10, 25), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 255), 2)
    out.write(frame)

    if frame_idx % 50 == 0:
        elapsed = time.time() - start_time
        fps_proc = frame_idx / elapsed
        eta = (total_frames - frame_idx) / fps_proc if fps_proc > 0 else 0
        print(f"  [{frame_idx}/{total_frames}] {fps_proc:.1f} FPS | ETA: {eta:.0f}s")

cap.release()
out.release()

elapsed = time.time() - start_time
print(f"\n✅ Done! {frame_idx} frames in {elapsed:.1f}s")
print(f"📹 Saved to: {OUTPUT_VIDEO}")

