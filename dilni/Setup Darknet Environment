import os

# Clone darknet repo
!git clone https://github.com/AlexeyAB/darknet /kaggle/working/darknet_new
os.chdir('/kaggle/working/darknet_new')
print("✅ Darknet cloned!")

# Install OpenCV
!apt-get install -y libopencv-dev

# Enable GPU, CUDNN, and OpenCV in Makefile
!sed -i 's/GPU=0/GPU=1/' Makefile
!sed -i 's/CUDNN=0/CUDNN=1/' Makefile
!sed -i 's/OPENCV=0/OPENCV=1/' Makefile
!sed -i 's|-L/usr/local/cuda/lib64|-L/usr/local/nvidia/lib64 -L/usr/local/cuda/lib64 -lcuda|' Makefile
!sed -i 's|-lcuda |-lcuda -Wl,-rpath,/usr/local/nvidia/lib64 |' Makefile

# Compile Darknet
!make -j4 2>&1 | tail -5

# Verify compilation
if os.path.exists('darknet'):
    print("✅ Compiled with GPU!")
    !./darknet version
else:
    print("❌ Failed to compile Darknet")
