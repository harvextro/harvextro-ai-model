import os
from pathlib import Path

# 1. CLEANUP: Remove potentially corrupted files
if os.path.exists("yolov8n.pt"):
    os.remove("yolov8n.pt")
    print("🗑️ Removed existing yolov8n.pt to prevent corruption errors.")

# 2. INITIALIZE MODEL
# This will re-download the weights cleanly
model = YOLO(f"yolov8{MODEL_SIZE}.pt") 

# 3. TRAIN
try:
    results = model.train(
        data    = "/kaggle/working/harvextro_yolov8/dataset.yaml",
        epochs  = EPOCHS,
        batch   = BATCH_SIZE,
        imgsz   = IMG_SIZE,
        lr0     = LR0,
        patience= PATIENCE,
        project = f"{OUTPUT_ROOT}/runs",
        name    = RUN_NAME,
        save    = True,
        plots   = True,
        verbose = True,
        device  = 0 if torch.cuda.is_available() else "cpu",
        # Augmentation settings
        hsv_h   = 0.015,
        hsv_s   = 0.7,
        hsv_v   = 0.4,
        flipud  = 0.0,
        fliplr  = 0.5,
        mosaic  = 1.0,
        mixup   = 0.1,
    )
    
    best_weights = Path(results.save_dir) / "weights" / "best.pt"
    print(f"✅ Training complete. Best weights: {best_weights}")

except Exception as e:
    print(f"❌ Training failed with error: {e}")
    print("Tip: If you still see 'PytorchStreamReader' errors, try toggling the 'Internet' switch in the Kaggle sidebar to OFF and then back to ON.")
